@page "/istasyon/{Icao}/notam"
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>@Icao NOTAM — MetarPulse</PageTitle>

@* ── Başlık ──────────────────────────────────────────────────────────────── *@
<div class="flex items-center justify-between mb-3">
    <div>
        <h1 class="text-base font-semibold text-base-content">
            <button class="btn btn-ghost btn-xs px-0 mr-1" @onclick="GoBack">
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </button>
            <span class="font-mono text-primary">@Icao</span>
            <span class="text-base-content/50 font-normal ml-1">NOTAM</span>
        </h1>
    </div>
    <button class="btn btn-ghost btn-sm btn-circle" @onclick="LoadAsync" disabled="@_loading">
        @if (_loading)
        {
            <span class="loading loading-spinner loading-xs"></span>
        }
        else
        {
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
        }
    </button>
</div>

@* ── Filtreler ────────────────────────────────────────────────────────────── *@
<div class="flex gap-2 mb-3 flex-wrap">
    <button class="btn btn-xs @(_filter == "all"      ? "btn-primary" : "btn-ghost")" @onclick='() => SetFilter("all")'>Tümü (@_notams.Count)</button>
    <button class="btn btn-xs @(_filter == "Warning"  ? "btn-error"   : "btn-ghost")" @onclick='() => SetFilter("Warning")'>Uyarı (@_notams.Count(n => n.VfrImpact == "Warning"))</button>
    <button class="btn btn-xs @(_filter == "Caution"  ? "btn-warning" : "btn-ghost")" @onclick='() => SetFilter("Caution")'>Dikkat (@_notams.Count(n => n.VfrImpact == "Caution"))</button>
    <button class="btn btn-xs @(_filter == "Advisory" ? "btn-info"    : "btn-ghost")" @onclick='() => SetFilter("Advisory")'>Bilgi (@_notams.Count(n => n.VfrImpact == "Advisory"))</button>
</div>

@* ── İçerik ───────────────────────────────────────────────────────────────── *@
@if (_loading && _notams.Count == 0)
{
    <div class="flex justify-center py-12">
        <span class="loading loading-ring loading-lg text-primary"></span>
    </div>
}
else if (Filtered.Count == 0 && !_loading)
{
    <div class="flex flex-col items-center justify-center gap-3 mt-16 text-center px-4">
        <svg class="w-12 h-12 text-base-content/20" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <p class="text-base-content/50">Aktif NOTAM yok</p>
    </div>
}
else
{
    <div class="flex flex-col gap-2">
        @foreach (var notam in Filtered)
        {
            <div class="card bg-base-200 border border-base-300 rounded-xl overflow-hidden card-@notam.VfrImpact.ToLower()">
                <button class="w-full text-left p-3" @onclick="() => Toggle(notam.NotamId)">
                    <div class="flex items-start justify-between gap-2">
                        <div class="flex items-center gap-2 flex-wrap">
                            <span class="badge badge-sm @ImpactBadgeCss(notam.VfrImpact) font-mono">@notam.VfrImpact</span>
                            @if (notam.Traffic is "Vfr" or "All")
                            {
                                <span class="badge badge-xs badge-traffic-vfr font-mono">VFR</span>
                            }
                            @if (notam.Traffic is "Ifr" or "All")
                            {
                                <span class="badge badge-xs badge-traffic-ifr font-mono">IFR</span>
                            }
                            <span class="font-mono text-xs font-semibold text-base-content">@notam.NotamId</span>
                            @if (!string.IsNullOrEmpty(notam.Subject))
                            {
                                <span class="text-xs text-base-content/50">@notam.Subject</span>
                            }
                        </div>
                        <svg class="w-4 h-4 flex-shrink-0 text-base-content/30 transition-transform @(_expanded.Contains(notam.NotamId) ? "rotate-180" : "")"
                             xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>
                    <p class="text-xs text-base-content/40 mt-1">@ValidityText(notam)</p>
                    @if (!_expanded.Contains(notam.NotamId))
                    {
                        <p class="text-xs text-base-content/60 mt-1 line-clamp-2">@notam.RawText</p>
                    }
                </button>

                @if (_expanded.Contains(notam.NotamId))
                {
                    <div class="border-t border-base-300 px-3 pb-3 pt-2">
                        <pre class="text-xs text-base-content/70 whitespace-pre-wrap font-mono leading-relaxed">@notam.RawText</pre>
                        @if (!string.IsNullOrEmpty(notam.Schedule))
                        {
                            <p class="text-xs text-base-content/40 mt-2">
                                <span class="font-semibold">Takvim:</span> @notam.Schedule
                            </p>
                        }
                        @if (!string.IsNullOrEmpty(notam.LowerLimit) || !string.IsNullOrEmpty(notam.UpperLimit))
                        {
                            <p class="text-xs text-base-content/40 mt-1">
                                <span class="font-semibold">İrtifa:</span>
                                @notam.LowerLimit – @notam.UpperLimit
                            </p>
                        }
                        <div class="flex gap-2 mt-2 flex-wrap">
                            <span class="badge badge-ghost badge-xs">@notam.Traffic</span>
                            <span class="badge badge-ghost badge-xs">@notam.Scope</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public string Icao { get; set; } = string.Empty;

    private List<NotamDto> _notams = new();
    private readonly HashSet<string> _expanded = new();
    private bool _loading;
    private string _filter = "all";

    private List<NotamDto> Filtered =>
        _filter == "all" ? _notams : _notams.Where(n => n.VfrImpact == _filter).ToList();

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<List<NotamDto>>($"api/notam/{Icao.ToUpperInvariant()}");
            _notams = result ?? [];
        }
        catch { _notams = []; }
        finally { _loading = false; }
    }

    private void Toggle(string notamId)
    {
        if (!_expanded.Add(notamId))
            _expanded.Remove(notamId);
    }

    private void SetFilter(string filter) => _filter = filter;

    private void GoBack() => Nav.NavigateTo($"/istasyon/{Icao}");

    private static string ImpactBadgeCss(string impact) => impact switch
    {
        "Warning"  => "badge-error",
        "Caution"  => "badge-warning",
        "Advisory" => "badge-info",
        _          => "badge-ghost"
    };

    private static string ValidityText(NotamDto n)
    {
        if (n.IsPermanent) return "PERM";
        var from = n.EffectiveFrom.ToUniversalTime().ToString("ddHHmm");
        var to = n.EffectiveTo?.ToUniversalTime().ToString("ddHHmm") ?? "PERM";
        return $"{from}Z – {to}Z";
    }

    private record NotamDto(
        string NotamId,
        string AirportIdent,
        string Subject,
        string Traffic,
        string Scope,
        string VfrImpact,
        DateTime EffectiveFrom,
        DateTime? EffectiveTo,
        bool IsPermanent,
        string? Schedule,
        string LowerLimit,
        string UpperLimit,
        string RawText,
        string SourceProvider
    );
}
