@page "/"
@inject HttpClient Http
@inject NavigationManager Nav
@inject IConfiguration Config
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text.Json

<PageTitle>MetarPulse — METAR/TAF</PageTitle>

@* ── Hero / Arama ─────────────────────────────────────────────────────── *@
<div class="text-center mb-8">
    <h1 class="text-3xl font-bold mb-1">
        Metar<span class="text-primary">Pulse</span>
    </h1>
    <p class="text-base-content/70 text-sm mb-6">Gerçek zamanlı METAR · TAF · Pist Analizi</p>

    <div class="join max-w-sm mx-auto w-full">
        <input class="input input-bordered join-item flex-1 font-mono uppercase text-center tracking-widest"
               placeholder="LTFM"
               maxlength="4"
               @bind="_icao"
               @bind:event="oninput"
               @onkeydown="OnKeyDown" />
        <button class="btn btn-primary join-item"
                @onclick="GoToStation"
                disabled="@(_icao.Length < 3)">
            Ara
        </button>
    </div>
</div>

@* ── Popüler istasyonlar ───────────────────────────────────────────────── *@
<div class="mb-6">
    <div class="text-xs text-base-content/60 uppercase tracking-wider mb-3">Hızlı Erişim</div>
    <div class="flex flex-wrap gap-2">
        @foreach (var icao in _popular)
        {
            <button class="btn btn-outline btn-sm font-mono" @onclick="() => NavigateTo(icao)">
                @icao
            </button>
        }
    </div>
</div>

@* ── Çoklu METAR ──────────────────────────────────────────────────────── *@
@if (_loading)
{
    <div class="flex justify-center py-8">
        <span class="loading loading-ring loading-lg text-primary"></span>
    </div>
}
else if (_metars.Count > 0)
{
    <div class="grid gap-3 md:grid-cols-2">
        @foreach (var m in _metars)
        {
            var flashClass = _flashingStations.Contains(m.StationId) ? $"flash-{m.Category.ToLower()}" : "";
            <div class="card bg-base-200 border border-base-300 rounded-xl cursor-pointer hover:border-primary/40 transition-colors @flashClass"
                 @onclick="() => NavigateTo(m.StationId)">
                <div class="card-body p-3">
                    <div class="flex items-center justify-between mb-2">
                        <span class="font-mono font-bold text-lg text-base-content tracking-widest">@m.StationId</span>
                        <span class="badge badge-sm @CategoryBadgeClass(m.Category)">@m.Category</span>
                    </div>
                    <div class="flex items-center gap-4 text-sm text-base-content/85">
                        <span>💨 @m.WindDirection°/@m.WindSpeed kt@(m.WindGust.HasValue ? $" G{m.WindGust}" : "")</span>
                        <span>👁 @VisText(m.VisibilityMeters)</span>
                        <span>☁ @CeilText(m.CeilingFeet)</span>
                    </div>
                    <div class="text-[0.65rem] font-mono text-base-content/50 mt-1 truncate">@m.RawText</div>
                </div>
            </div>
        }
    </div>
}

@code {
    private string _icao = string.Empty;
    private bool _loading = true;
    private List<MetarDto> _metars = new();
    private readonly HashSet<string> _flashingStations = new();
    private HubConnection? _hub;
    private System.Threading.Timer? _pollTimer;

    private static readonly string[] _popular = ["LTBU","LTFD", "LTBR","LTBH","LTFM"];

    protected override async Task OnInitializedAsync()
    {
        await LoadMetarsAsync();
        await ConnectSignalRAsync();

        // SignalR push yoksa fallback: 5 dakikada bir yenile
        _pollTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await RefreshAndFlashChangedAsync();
                StateHasChanged();
            });
        }, null, TimeSpan.FromMinutes(5), TimeSpan.FromMinutes(5));
    }

    private async Task LoadMetarsAsync()
    {
        try
        {
            var bulkIcaos = string.Join(",", _popular);
            var result = await Http.GetFromJsonAsync<List<MetarDto>>($"api/metar/bulk?icao={bulkIcaos}");
            _metars = result ?? new();
        }
        catch { }
        finally { _loading = false; }
    }

    // Polling fallback: değişen istasyonları güncelle + flash tetikle
    private async Task RefreshAndFlashChangedAsync()
    {
        try
        {
            var bulkIcaos = string.Join(",", _popular);
            var fresh = await Http.GetFromJsonAsync<List<MetarDto>>($"api/metar/bulk?icao={bulkIcaos}");
            if (fresh is null) return;

            foreach (var f in fresh)
            {
                var idx = _metars.FindIndex(m => m.StationId == f.StationId);
                if (idx < 0) { _metars.Add(f); continue; }

                // ObservationTime değiştiyse flash tetikle
                if (_metars[idx].ObservationTime < f.ObservationTime)
                {
                    _metars[idx] = f;
                    _ = FlashAsync(f.StationId);
                }
                else
                {
                    _metars[idx] = f;
                }
            }
        }
        catch { }
    }

    private async Task FlashAsync(string icao)
    {
        _flashingStations.Add(icao);
        StateHasChanged();
        await Task.Delay(5000);
        _flashingStations.Remove(icao);
        StateHasChanged();
    }

    private async Task ConnectSignalRAsync()
    {
        var apiBase = Config["ApiBaseUrl"] ?? "http://localhost:5000/";
        var hubUrl = apiBase.TrimEnd('/') + "/hubs/metar";

        _hub = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        _hub.On<JsonElement>("ReceiveMetar", async payload =>
        {
            var icao = "";
            if (payload.TryGetProperty("stationId", out var p)) icao = p.GetString() ?? "";
            else if (payload.TryGetProperty("StationId", out var p2)) icao = p2.GetString() ?? "";
            if (string.IsNullOrEmpty(icao)) return;

            await InvokeAsync(async () =>
            {
                try
                {
                    var fresh = await Http.GetFromJsonAsync<MetarDto>($"api/metar/{icao}");
                    if (fresh is null) return;
                    var idx = _metars.FindIndex(m => m.StationId == icao);
                    if (idx >= 0) _metars[idx] = fresh;

                    _flashingStations.Add(icao);
                    StateHasChanged();

                    await Task.Delay(5000);
                    _flashingStations.Remove(icao);
                    StateHasChanged();
                }
                catch { }
            });
        });

        try
        {
            await _hub.StartAsync();
            foreach (var icao in _popular)
                await _hub.InvokeAsync("JoinStationAsync", icao);
        }
        catch { /* SignalR bağlanamadı, polling ile devam */ }
    }

    private void GoToStation()
    {
        if (_icao.Length >= 3)
            Nav.NavigateTo($"/istasyon/{_icao.ToUpperInvariant()}");
    }

    private void NavigateTo(string icao) => Nav.NavigateTo($"/istasyon/{icao}");

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") GoToStation();
    }

    private static string CategoryBadgeClass(string cat) => cat switch
    {
        "VFR"  => "badge-success",
        "MVFR" => "badge-info",
        "IFR"  => "badge-warning",
        "LIFR" => "badge-error",
        _      => "badge-ghost"
    };

    private static string VisText(int m) => m >= 9999 ? "9999m" : $"{m}m";
    private static string CeilText(int ft) => ft >= 9999 ? "CLR" : $"{ft:N0}ft";

    public async ValueTask DisposeAsync()
    {
        _pollTimer?.Dispose();
        if (_hub is not null)
            await _hub.DisposeAsync();
    }

    private record MetarDto(
        string StationId, string RawText, DateTime ObservationTime,
        int WindDirection, int WindSpeed, int? WindGust,
        bool IsVariableWind, int? VariableWindFrom, int? VariableWindTo,
        int VisibilityMeters, int CeilingFeet, string Category,
        int? Temperature, int? DewPoint, decimal? AltimeterHpa, decimal? AltimeterInHg,
        string? Trend, bool IsSpeci, string? SourceProvider, DateTime FetchedAt,
        List<object> CloudLayers, List<string> WeatherConditions, bool IsStale = false);
}
