@inherits LayoutComponentBase
@attribute [Authorize(Roles = "Admin")]

<div class="flex" style="height: 100vh; overflow: hidden;">

    @* ── Sidebar ──────────────────────────────────────────────────────────── *@
    <aside class="admin-sidebar">

        @* Logo *@
        <div class="px-4 py-4 border-b border-base-300 flex items-center gap-2.5">
            <div class="w-7 h-7 rounded-lg bg-primary flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-primary-content" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                          d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
                </svg>
            </div>
            <div>
                <div class="logo-text">Metar<span class="logo-accent">Pulse</span></div>
                <div class="opacity-40 font-medium tracking-widest uppercase" style="font-size:9px; margin-top:-1px;">Admin</div>
            </div>
        </div>

        @* Nav *@
        <nav class="flex-1 px-2 py-3 overflow-y-auto">
            <div class="nav-section-label">Genel</div>

            <NavLink class="nav-item" href="/" Match="NavLinkMatch.All" ActiveClass="active">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                <span>Dashboard</span>
            </NavLink>

            <div class="nav-section-label">Sistem</div>

            <NavLink class="nav-item" href="/providers" ActiveClass="active">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />
                </svg>
                <span>Veri Kaynakları</span>
            </NavLink>

            <NavLink class="nav-item" href="/cache" ActiveClass="active">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
                </svg>
                <span>Cache</span>
            </NavLink>

            <NavLink class="nav-item" href="/notams" ActiveClass="active">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
                <span>NOTAM</span>
            </NavLink>

            <NavLink class="nav-item" href="/logs" ActiveClass="active">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                <span>Loglar</span>
            </NavLink>

            <div class="nav-section-label">Kullanıcılar</div>

            <NavLink class="nav-item" href="/users" ActiveClass="active">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>Kullanıcılar</span>
            </NavLink>

            <NavLink class="nav-item" href="/settings" ActiveClass="active">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>Ayarlar</span>
            </NavLink>
        </nav>

        @* Bottom — User & Logout *@
        <div class="border-t border-base-300 p-2.5">
            <AuthorizeView>
                <Authorized>
                    <div class="flex items-center gap-2.5 px-2 py-2 rounded-lg hover:bg-base-200 transition-colors">
                        <div class="user-avatar bg-primary text-primary-content text-xs font-bold">
                            @GetInitials(context.User.Identity?.Name)
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="text-xs font-semibold truncate">@GetDisplayName(context.User.Identity?.Name)</div>
                            <div class="opacity-40 font-medium" style="font-size:10px;">Administrator</div>
                        </div>
                        <form method="post" action="/logout" class="logout-form">
                            <AntiforgeryToken />
                            <button type="submit" title="Çıkış Yap"
                                    class="w-7 h-7 rounded-lg flex items-center justify-center hover:bg-error hover:text-error-content transition-colors opacity-40 hover:opacity-100">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                </svg>
                            </button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>

    @* ── Main Content ──────────────────────────────────────────────────────── *@
    <div class="admin-content">

        @* Topbar *@
        <div class="admin-topbar">
            <div class="flex-1 min-w-0"></div>

            @* Theme Toggle — pure JS *@
            <button class="btn btn-ghost btn-sm btn-circle"
                    onclick="(function(){var h=document.documentElement;var t=h.getAttribute('data-theme')==='dark'?'light':'dark';h.setAttribute('data-theme',t);try{localStorage.setItem('mp-theme',t);}catch(e){}})()">
                <svg class="w-4 h-4 theme-icon-sun" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 3v1m0 16v1m8.66-9h-1M4.34 12h-1m15.07-6.36l-.71.71M5.64 18.36l-.71.71m12.73 0l-.71-.71M5.64 5.64l-.71-.71M12 7a5 5 0 100 10A5 5 0 0012 7z" />
                </svg>
                <svg class="w-4 h-4 theme-icon-moon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
                </svg>
            </button>

            @* API status *@
            <div class="flex items-center gap-1.5 text-xs font-medium opacity-50">
                <span class="w-1.5 h-1.5 rounded-full bg-success inline-block"></span>
                <span>API</span>
            </div>
        </div>

        @* Page Content *@
        <div class="admin-page">
            @Body
        </div>
    </div>
</div>

@code {
    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "A";
        var parts = name.Split('@')[0].Split('.');
        if (parts.Length >= 2)
            return $"{char.ToUpper(parts[0][0])}{char.ToUpper(parts[1][0])}";
        return char.ToUpper(name[0]).ToString();
    }

    private static string GetDisplayName(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "Admin";
        return name.Contains('@') ? name.Split('@')[0] : name;
    }
}
