<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>MetarPulse Admin</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Tailwind + DaisyUI CDN -->
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5/dist/full.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@@4"></script>
    <link rel="stylesheet" href="app.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <script>
        // Anti-FOUC + theme helpers (in <head> so always available before Blazor circuit)
        (function () {
            try {
                var t = localStorage.getItem('mp-theme') || 'night';
                document.documentElement.setAttribute('data-theme', t);
            } catch (e) { }
        })();
        window.mpGetTheme = function () {
            return document.documentElement.getAttribute('data-theme') || 'night';
        };
        window.mpSetTheme = function (theme) {
            document.documentElement.setAttribute('data-theme', theme);
            try { localStorage.setItem('mp-theme', theme); } catch (e) { }
        };
    </script>
    <HeadOutlet />
</head>

<body class="bg-base-200 min-h-screen">
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: true)" />
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
