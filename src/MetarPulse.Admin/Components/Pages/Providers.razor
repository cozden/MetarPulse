@page "/providers"
@attribute [Authorize(Roles = "Admin")]

@inject IHttpClientFactory HttpFactory
@inject ILogger<Providers> Logger

<PageTitle>Provider Yönetimi — MetarPulse Admin</PageTitle>

<div class="mb-6">
    <h1 class="text-xl font-bold text-base-content">Provider Yönetimi</h1>
    <p class="text-sm text-base-content/60 mt-1">METAR/TAF veri kaynaklarının durumu ve öncelik sırası</p>
</div>

@if (_loading)
{
    <div class="flex items-center gap-3 text-base-content/60">
        <span class="loading loading-spinner loading-sm"></span>
        <span>Yükleniyor...</span>
    </div>
}
else if (_error is not null)
{
    <div class="alert alert-error text-sm mb-4">
        <span>@_error</span>
        <button class="btn btn-sm btn-ghost ml-auto" @onclick="LoadAsync">Yeniden Dene</button>
    </div>
}
else
{
    <div class="flex items-center justify-between mb-4">
        <div class="text-sm text-base-content/50">@_providers.Count provider kayıtlı</div>
        <button class="btn btn-sm btn-outline" @onclick="LoadAsync" disabled="@_busy">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            Yenile
        </button>
    </div>

    <div class="overflow-x-auto rounded-xl shadow-sm">
        <table class="table table-zebra bg-base-100 w-full">
            <thead>
                <tr class="text-xs text-base-content/60 uppercase">
                    <th class="w-6"></th>
                    <th>Öncelik</th>
                    <th>Provider</th>
                    <th>Durum</th>
                    <th>Circuit</th>
                    <th>Son Başarı</th>
                    <th>Son Hata</th>
                    <th class="text-center">Aktif</th>
                    <th class="text-center">Sıra</th>
                    <th class="text-center">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (p, idx) in _providers.Select((p, i) => (p, i)))
                {
                    <tr class="hover transition-colors @(_dragOverIdx == idx && _dragSourceIdx >= 0 && _dragSourceIdx != idx ? "bg-primary/10 outline outline-2 outline-primary/20" : "")"
                        draggable="true"
                        @ondragstart="() => DragStart(idx)"
                        @ondragover:preventDefault="true"
                        @ondragenter="() => DragEnter(idx)"
                        @ondrop="() => DropAsync(idx)">
                        <td class="w-6 cursor-grab text-base-content/25 hover:text-base-content/60 select-none">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M7 2a2 2 0 1 0 .001 4.001A2 2 0 0 0 7 2zm0 6a2 2 0 1 0 .001 4.001A2 2 0 0 0 7 8zm0 6a2 2 0 1 0 .001 4.001A2 2 0 0 0 7 14zm6-8a2 2 0 1 0-.001-4.001A2 2 0 0 0 13 6zm0 2a2 2 0 1 0 .001 4.001A2 2 0 0 0 13 8zm0 6a2 2 0 1 0 .001 4.001A2 2 0 0 0 13 14z"/>
                            </svg>
                        </td>
                        <td class="font-mono text-sm w-12 text-center">@p.Priority</td>
                        <td>
                            <div class="font-semibold text-sm">@p.ProviderName</div>
                            @if (p.HasDbOverride)
                            {
                                <span class="badge badge-info badge-xs mt-0.5">override</span>
                            }
                        </td>
                        <td>
                            @if (!p.IsEnabled)
                            {
                                <span class="badge badge-ghost badge-sm">Pasif</span>
                            }
                            else if (p.IsCircuitOpen)
                            {
                                <span class="badge badge-warning badge-sm">Circuit Açık</span>
                            }
                            else if (p.IsHealthy)
                            {
                                <span class="badge badge-success badge-sm">OK</span>
                            }
                            else
                            {
                                <span class="badge badge-error badge-sm">HATA</span>
                            }
                        </td>
                        <td class="text-xs text-base-content/50">
                            @if (p.IsCircuitOpen) { <span class="text-warning">Açık</span> }
                            else { <span>Kapalı</span> }
                        </td>
                        <td class="text-xs text-base-content/50">
                            @(p.LastSuccess.HasValue ? p.LastSuccess.Value.ToString("dd.MM HH:mm") + "Z" : "—")
                        </td>
                        <td class="text-xs max-w-[200px] truncate text-error/70" title="@p.LastError">
                            @(p.LastError ?? "—")
                        </td>
                        <td class="text-center">
                            <input type="checkbox" class="toggle toggle-success toggle-sm"
                                   checked="@p.IsEnabled"
                                   disabled="@_busy"
                                   @onchange="e => ToggleEnabledAsync(p.ProviderName, (bool)e.Value!)" />
                        </td>
                        <td class="text-center">
                            <div class="flex items-center justify-center gap-1">
                                <button class="btn btn-xs btn-ghost px-1"
                                        disabled="@(idx == 0 || _busy)"
                                        @onclick="() => MoveUpAsync(idx)">▲</button>
                                <button class="btn btn-xs btn-ghost px-1"
                                        disabled="@(idx == _providers.Count - 1 || _busy)"
                                        @onclick="() => MoveDownAsync(idx)">▼</button>
                            </div>
                        </td>
                        <td class="text-center">
                            <div class="flex items-center justify-center gap-1">
                                @if (_testResults.TryGetValue(p.ProviderName, out var result))
                                {
                                    <span class="@(result.Success ? "text-success" : "text-error") text-xs">
                                        @(result.Success ? "✓" : "✗") @result.Message
                                    </span>
                                }
                                else
                                {
                                    <button class="btn btn-xs btn-outline"
                                            disabled="@_busy"
                                            @onclick="() => TestProviderAsync(p.ProviderName)">
                                        Test
                                    </button>
                                }
                                <button class="btn btn-xs btn-ghost" title="Ayarları Düzenle"
                                        disabled="@_busy"
                                        @onclick="() => OpenEditModal(p.ProviderName)">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_statusMessage is not null)
    {
        <div class="alert @(_statusIsError ? "alert-error" : "alert-success") text-sm mt-4">
            @_statusMessage
        </div>
    }
}

<!-- ── Edit Modal ────────────────────────────────────────────────────────── -->
@if (_editModal != null)
{
    <div class="modal modal-open">
        <div class="modal-box max-w-lg">
            <div class="flex items-center justify-between mb-4">
                <h3 class="font-bold text-lg">@_editModal.ProviderName — Ayarlar</h3>
                @if (_editModal.HasDbOverride)
                {
                    <span class="badge badge-info badge-sm">DB override aktif</span>
                }
            </div>

            @if (_editSaving)
            {
                <div class="flex justify-center py-8">
                    <span class="loading loading-spinner loading-md"></span>
                </div>
            }
            else
            {
                <div class="grid grid-cols-2 gap-3">
                    <div class="form-control col-span-2">
                        <label class="label py-1"><span class="label-text text-xs">Base URL</span></label>
                        <input type="text" class="input input-bordered input-sm"
                               @bind="_editForm.BaseUrl" placeholder="https://..." />
                    </div>
                    <div class="form-control col-span-2">
                        <label class="label py-1">
                            <span class="label-text text-xs">API Key</span>
                            <span class="label-text-alt text-xs text-base-content/40">Boş bırakırsan mevcut değer korunur</span>
                        </label>
                        <div class="relative">
                            <input type="@(_showApiKey ? "text" : "password")"
                                   class="input input-bordered input-sm w-full pr-10"
                                   @bind="_editForm.ApiKey" placeholder="••••••••" />
                            <button type="button"
                                    class="absolute right-2 top-1/2 -translate-y-1/2 text-base-content/40 hover:text-base-content"
                                    @onclick="() => _showApiKey = !_showApiKey">
                                @(_showApiKey ? "🙈" : "👁")
                            </button>
                        </div>
                    </div>
                    <div class="form-control">
                        <label class="label py-1"><span class="label-text text-xs">Timeout (sn)</span></label>
                        <input type="number" class="input input-bordered input-sm"
                               @bind="_editForm.TimeoutSeconds" min="1" max="60" />
                    </div>
                    <div class="form-control">
                        <label class="label py-1"><span class="label-text text-xs">Retry Sayısı</span></label>
                        <input type="number" class="input input-bordered input-sm"
                               @bind="_editForm.RetryCount" min="0" max="10" />
                    </div>
                    <div class="form-control">
                        <label class="label py-1"><span class="label-text text-xs">Circuit Breaker Eşiği</span></label>
                        <input type="number" class="input input-bordered input-sm"
                               @bind="_editForm.CircuitBreakerThreshold" min="1" max="50" />
                    </div>
                    <div class="form-control">
                        <label class="label py-1"><span class="label-text text-xs">Circuit Break Süresi (sn)</span></label>
                        <input type="number" class="input input-bordered input-sm"
                               @bind="_editForm.CircuitBreakerDurationSeconds" min="5" max="300" />
                    </div>
                </div>

                @if (_editModal.HasDbOverride)
                {
                    <div class="mt-3 text-xs text-base-content/50">
                        Son güncelleme: @_editModal.UpdatedAt?.ToString("dd.MM.yyyy HH:mm") — @(_editModal.UpdatedBy ?? "?")
                    </div>
                }

                <div class="modal-action mt-4 flex gap-2">
                    @if (_editModal.HasDbOverride)
                    {
                        <button class="btn btn-sm btn-ghost text-error" @onclick="ResetOverrideAsync">
                            Override Sil
                        </button>
                    }
                    <div class="flex-1"></div>
                    <button class="btn btn-sm btn-ghost" @onclick="CloseEditModal">İptal</button>
                    <button class="btn btn-sm btn-primary" @onclick="SaveEditAsync">Kaydet & Uygula</button>
                </div>
            }
        </div>
        <div class="modal-backdrop" @onclick="CloseEditModal"></div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private string? _statusMessage;
    private bool _statusIsError;
    private List<ProviderVm> _providers = [];
    private Dictionary<string, TestResult> _testResults = [];

    // Drag & drop state
    private int _dragSourceIdx = -1;
    private int _dragOverIdx   = -1;

    // Edit modal state
    private EditModalVm? _editModal;
    private EditFormVm _editForm = new();
    private bool _editSaving;
    private bool _showApiKey;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _testResults.Clear();
        StateHasChanged();
        try
        {
            var http = HttpFactory.CreateClient("MetarPulseApi");
            var providers = await http.GetFromJsonAsync<List<ProviderDto>>("api/providers");
            var health    = await http.GetFromJsonAsync<List<HealthDto>>("api/providers/health");
            var healthMap = health?.ToDictionary(h => h.ProviderName, StringComparer.OrdinalIgnoreCase) ?? [];

            _providers = (providers ?? [])
                .OrderBy(p => p.Priority)
                .Select(p =>
                {
                    healthMap.TryGetValue(p.ProviderName, out var h);
                    return new ProviderVm
                    {
                        ProviderName  = p.ProviderName,
                        Priority      = p.Priority,
                        IsEnabled     = p.IsEnabled,
                        IsHealthy     = h?.IsHealthy ?? false,
                        IsCircuitOpen = h?.IsCircuitOpen ?? false,
                        LastSuccess   = h?.LastSuccess,
                        LastError     = h?.LastError,
                        HasDbOverride = false // settings çağrısından güncellenir
                    };
                })
                .ToList();

            // Her provider için override bilgisini yükle
            foreach (var p in _providers)
            {
                try
                {
                    var s = await http.GetFromJsonAsync<ProviderSettingsDto>(
                        $"api/admin/providers/{Uri.EscapeDataString(p.ProviderName)}/settings");
                    p.HasDbOverride = s?.HasDbOverride ?? false;
                }
                catch { /* sessizce geç */ }
            }
        }
        catch (Exception ex)
        {
            _error = $"API'ye bağlanılamadı: {ex.Message}";
        }
        finally { _loading = false; }
    }

    private async Task OpenEditModal(string name)
    {
        _editSaving = false;
        _showApiKey = false;
        try
        {
            var http = HttpFactory.CreateClient("MetarPulseApi");
            var s = await http.GetFromJsonAsync<ProviderSettingsDto>(
                $"api/admin/providers/{Uri.EscapeDataString(name)}/settings");

            _editModal = new EditModalVm
            {
                ProviderName  = name,
                HasDbOverride = s?.HasDbOverride ?? false,
                UpdatedAt     = s?.Override?.UpdatedAt,
                UpdatedBy     = s?.Override?.UpdatedBy
            };

            // Override varsa override, yoksa aktif (runtime) config ile doldur
            _editForm = new EditFormVm
            {
                BaseUrl                       = s?.Override?.BaseUrl
                                                ?? s?.Active?.BaseUrl,
                ApiKey                        = null, // şifreyi gösterme, boş bırak
                TimeoutSeconds                = s?.Override?.TimeoutSeconds
                                                ?? s?.Active?.TimeoutSeconds ?? 5,
                RetryCount                    = s?.Override?.RetryCount
                                                ?? s?.Active?.RetryCount ?? 2,
                CircuitBreakerThreshold       = s?.Override?.CircuitBreakerThreshold
                                                ?? s?.Active?.CircuitBreakerThreshold ?? 5,
                CircuitBreakerDurationSeconds = s?.Override?.CircuitBreakerDurationSeconds
                                                ?? s?.Active?.CircuitBreakerDurationSeconds ?? 30,
            };
        }
        catch (Exception ex)
        {
            ShowStatus($"Ayarlar yüklenemedi: {ex.Message}", true);
        }
    }

    private void CloseEditModal() => _editModal = null;

    private async Task SaveEditAsync()
    {
        if (_editModal == null) return;
        _editSaving = true;
        try
        {
            var http = HttpFactory.CreateClient("MetarPulseApi");
            var body = new
            {
                Enabled                      = (bool?)null,
                Priority                     = (int?)null,
                _editForm.BaseUrl,
                _editForm.ApiKey,
                _editForm.TimeoutSeconds,
                _editForm.RetryCount,
                _editForm.CircuitBreakerThreshold,
                _editForm.CircuitBreakerDurationSeconds
            };
            var resp = await http.PutAsJsonAsync(
                $"api/admin/providers/{Uri.EscapeDataString(_editModal.ProviderName)}/settings", body);
            if (resp.IsSuccessStatusCode)
            {
                ShowStatus($"{_editModal.ProviderName} ayarları kaydedildi ve uygulandı", false);
                CloseEditModal();
                await LoadAsync();
            }
            else
            {
                ShowStatus($"Kayıt başarısız: {resp.StatusCode}", true);
            }
        }
        catch (Exception ex) { ShowStatus(ex.Message, true); }
        finally { _editSaving = false; }
    }

    private async Task ResetOverrideAsync()
    {
        if (_editModal == null) return;
        _editSaving = true;
        try
        {
            var http = HttpFactory.CreateClient("MetarPulseApi");
            var resp = await http.DeleteAsync(
                $"api/admin/providers/{Uri.EscapeDataString(_editModal.ProviderName)}/settings");
            if (resp.IsSuccessStatusCode)
            {
                ShowStatus($"{_editModal.ProviderName} override silindi", false);
                CloseEditModal();
                await LoadAsync();
            }
        }
        catch (Exception ex) { ShowStatus(ex.Message, true); }
        finally { _editSaving = false; }
    }

    private async Task ToggleEnabledAsync(string name, bool enabled)
    {
        _busy = true; _statusMessage = null;
        try
        {
            var http = HttpFactory.CreateClient("MetarPulseApi");
            var resp = await http.PutAsJsonAsync(
                $"api/admin/providers/{Uri.EscapeDataString(name)}/settings",
                new { Enabled = (bool?)enabled, Priority = (int?)null, BaseUrl = (string?)null,
                      ApiKey = (string?)null, TimeoutSeconds = (int?)null, RetryCount = (int?)null,
                      CircuitBreakerThreshold = (int?)null, CircuitBreakerDurationSeconds = (int?)null });
            if (resp.IsSuccessStatusCode) { ShowStatus($"{name} → {(enabled ? "Aktif" : "Pasif")} (kaydedildi)", false); await LoadAsync(); }
            else ShowStatus($"Başarısız: {resp.StatusCode}", true);
        }
        catch (Exception ex) { ShowStatus(ex.Message, true); }
        finally { _busy = false; }
    }

    private void DragStart(int idx)
    {
        _dragSourceIdx = idx;
        _dragOverIdx   = -1;
    }

    private void DragEnter(int idx)
    {
        if (_dragOverIdx == idx) return;
        _dragOverIdx = idx;
        StateHasChanged();
    }

    private async Task DropAsync(int targetIdx)
    {
        var src = _dragSourceIdx;
        _dragSourceIdx = -1;
        _dragOverIdx   = -1;
        if (src < 0 || src == targetIdx) return;
        var item = _providers[src];
        _providers.RemoveAt(src);
        _providers.Insert(targetIdx, item);
        await SaveOrderAsync();
    }

    private async Task MoveUpAsync(int idx)
    {
        if (idx == 0) return;
        (_providers[idx], _providers[idx - 1]) = (_providers[idx - 1], _providers[idx]);
        await SaveOrderAsync();
    }

    private async Task MoveDownAsync(int idx)
    {
        if (idx >= _providers.Count - 1) return;
        (_providers[idx], _providers[idx + 1]) = (_providers[idx + 1], _providers[idx]);
        await SaveOrderAsync();
    }

    private async Task SaveOrderAsync()
    {
        _busy = true; _statusMessage = null;
        try
        {
            var http = HttpFactory.CreateClient("MetarPulseApi");
            // Her provider'ın yeni Priority değerini DB'ye kaydet
            for (int i = 0; i < _providers.Count; i++)
            {
                var resp = await http.PutAsJsonAsync(
                    $"api/admin/providers/{Uri.EscapeDataString(_providers[i].ProviderName)}/settings",
                    new { Enabled = (bool?)null, Priority = (int?)i, BaseUrl = (string?)null,
                          ApiKey = (string?)null, TimeoutSeconds = (int?)null, RetryCount = (int?)null,
                          CircuitBreakerThreshold = (int?)null, CircuitBreakerDurationSeconds = (int?)null });
                if (!resp.IsSuccessStatusCode)
                {
                    ShowStatus($"Sıralama kaydedilemedi: {_providers[i].ProviderName}", true);
                    return;
                }
            }
            ShowStatus("Sıralama kaydedildi", false);
            await LoadAsync();
        }
        catch (Exception ex) { ShowStatus(ex.Message, true); }
        finally { _busy = false; }
    }

    private async Task TestProviderAsync(string name)
    {
        _busy = true; _statusMessage = null;
        try
        {
            var http = HttpFactory.CreateClient("MetarPulseApi");
            var resp = await http.PostAsync($"api/providers/{Uri.EscapeDataString(name)}/test", null);
            var body = await resp.Content.ReadFromJsonAsync<TestResultDto>();
            _testResults[name] = new TestResult(body?.Success ?? false, body?.Message ?? resp.StatusCode.ToString());
        }
        catch (Exception ex) { _testResults[name] = new TestResult(false, ex.Message); }
        finally { _busy = false; }
    }

    private void ShowStatus(string msg, bool isError) { _statusMessage = msg; _statusIsError = isError; }

    // ── DTO'lar ──────────────────────────────────────────────────────────────
    private record ProviderDto(string ProviderName, int Priority, bool IsEnabled, bool IsHealthy);
    private record HealthDto(string ProviderName, bool IsHealthy, bool IsCircuitOpen, int ConsecutiveFailures,
        string LastChecked, DateTime? LastSuccess, string? LastError);
    private record TestResultDto(bool Success, string Message);
    private record TestResult(bool Success, string Message);

    private record ProviderSettingsDto(
        string ProviderName, bool HasDbOverride,
        ProviderActiveDto? Active,
        ProviderOverrideDto? Override);

    private record ProviderActiveDto(
        string? BaseUrl, bool ApiKeySet, int TimeoutSeconds, int RetryCount,
        int CircuitBreakerThreshold, int CircuitBreakerDurationSeconds);

    private record ProviderOverrideDto(
        string? BaseUrl, bool ApiKeySet, int? TimeoutSeconds, int? RetryCount,
        int? CircuitBreakerThreshold, int? CircuitBreakerDurationSeconds,
        DateTime? UpdatedAt, string? UpdatedBy);

    private class ProviderVm
    {
        public string    ProviderName  { get; set; } = "";
        public int       Priority      { get; set; }
        public bool      IsEnabled     { get; set; }
        public bool      IsHealthy     { get; set; }
        public bool      IsCircuitOpen { get; set; }
        public DateTime? LastSuccess   { get; set; }
        public string?   LastError     { get; set; }
        public bool      HasDbOverride { get; set; }
    }

    private class EditModalVm
    {
        public string    ProviderName  { get; set; } = "";
        public bool      HasDbOverride { get; set; }
        public DateTime? UpdatedAt     { get; set; }
        public string?   UpdatedBy     { get; set; }
    }

    private class EditFormVm
    {
        public string? BaseUrl                    { get; set; }
        public string? ApiKey                     { get; set; }
        public int     TimeoutSeconds             { get; set; } = 5;
        public int     RetryCount                 { get; set; } = 2;
        public int     CircuitBreakerThreshold    { get; set; } = 5;
        public int     CircuitBreakerDurationSeconds { get; set; } = 30;
    }
}
