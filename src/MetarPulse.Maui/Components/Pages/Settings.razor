@page "/ayarlar"
@inject ApiService Api
@inject ThemeService Theme
@inject BookmarkStateService BookmarkState

@* ── Ayarlar Sayfası ────────────────────────────────────────────────────── *@

<h1 class="text-base font-semibold text-base-content mb-4">Ayarlar</h1>

<div class="flex flex-col gap-3">

    @* Görünüm *@
    <div class="card bg-base-200 border border-base-300 rounded-xl">
        <div class="card-body p-4">
            <h2 class="text-sm font-semibold text-base-content mb-3">Görünüm</h2>

            <div class="flex items-center justify-between">
                <div>
                    <div class="text-sm text-base-content">Tema</div>
                    <div class="text-xs text-base-content/40">
                        @(Theme.IsDark ? "Koyu mod" : "Açık mod")
                    </div>
                </div>
                <label class="swap swap-rotate">
                    <input type="checkbox" checked="@(!Theme.IsDark)" @onchange="OnThemeToggle" />
                    @* Güneş — açık mod *@
                    <svg class="swap-on w-6 h-6 fill-current text-warning"
                         xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7,4.93,6.34A1,1,0,0,0,3.52,7.76L4.22,8.46A1,1,0,0,0,5.64,7Zm12,.06a1,1,0,0,0,.71-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.42A1,1,0,0,0,17.66,7.06ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"/>
                    </svg>
                    @* Ay — koyu mod *@
                    <svg class="swap-off w-6 h-6 fill-current text-base-content/60"
                         xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"/>
                    </svg>
                </label>
            </div>
        </div>
    </div>

    @* Birim seçimi *@
    <div class="card bg-base-200 border border-base-300 rounded-xl">
        <div class="card-body p-4">
            <h2 class="text-sm font-semibold text-base-content mb-3">Birimler</h2>

            <div class="flex items-center justify-between">
                <div>
                    <div class="text-sm text-base-content">Rüzgar hızı</div>
                    <div class="text-xs text-base-content/40">Knot veya km/h</div>
                </div>
                <select class="select select-bordered select-sm">
                    <option value="kt" selected>Knot (kt)</option>
                    <option value="kmh">km/h</option>
                    <option value="ms">m/s</option>
                </select>
            </div>

            <div class="divider my-2"></div>

            <div class="flex items-center justify-between">
                <div>
                    <div class="text-sm text-base-content">Görüş mesafesi</div>
                    <div class="text-xs text-base-content/40">Metre veya mil</div>
                </div>
                <select class="select select-bordered select-sm">
                    <option value="m" selected>Metre (m)</option>
                    <option value="sm">Statute Mile (SM)</option>
                </select>
            </div>
        </div>
    </div>

    @* Bildirim tercihleri — meydan kartları *@
    <div class="card bg-base-200 border border-base-300 rounded-xl">
        <div class="card-body p-4">
            <div class="flex items-center justify-between mb-3">
                <h2 class="text-sm font-semibold text-base-content">Bildirimler</h2>
                <button class="btn btn-ghost btn-xs text-primary" @onclick="ShowAddStation">
                    + Meydan
                </button>
            </div>

            @if (_prefsLoading)
            {
                <div class="flex justify-center py-4">
                    <span class="loading loading-spinner loading-sm text-primary"></span>
                </div>
            }
            else if (_allPrefs.Count == 0 && !_addingNew)
            {
                <div class="text-xs text-base-content/40 text-center py-3">
                    Henüz meydan eklenmedi. Ara sekmesinden veya yukaridaki + butonu ile ekleyebilirsiniz.
                </div>
            }
            else
            {
                <div class="flex flex-col gap-2">
                    @foreach (var pref in _allPrefs)
                    {
                        var icao = pref.StationIcao;
                        var expanded = _expandedIcao == icao;
                        <div class="rounded-lg bg-base-100 border border-base-300 overflow-hidden">
                            @* Kart başlığı *@
                            <button class="w-full flex items-center justify-between px-3 py-2.5 text-left"
                                    @onclick="() => ToggleExpand(icao)">
                                <span class="font-mono font-bold text-sm text-base-content">@icao</span>
                                <div class="flex items-center gap-2">
                                    <span class="text-[0.6rem] text-base-content/40">
                                        @NotifSummary(pref)
                                    </span>
                                    <span class="text-base-content/40 text-xs">@(expanded ? "▲" : "▼")</span>
                                </div>
                            </button>

                            @* Genişletilmiş içerik *@
                            @if (expanded)
                            {
                                <div class="px-3 pb-3 flex flex-col gap-2 border-t border-base-300/50 pt-2.5">
                                    <div class="flex items-center justify-between">
                                        <span class="text-xs text-base-content">Her yeni METAR</span>
                                        <input type="checkbox" class="toggle toggle-primary toggle-xs"
                                               checked="@pref.NotifyOnEveryMetar"
                                               @onchange="e => pref.NotifyOnEveryMetar = (bool)(e.Value ?? false)" />
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-xs text-base-content">Kategori değisince</span>
                                        <input type="checkbox" class="toggle toggle-primary toggle-xs"
                                               checked="@pref.NotifyOnCategoryChange"
                                               @onchange="e => pref.NotifyOnCategoryChange = (bool)(e.Value ?? false)" />
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-xs text-base-content">SPECI yayinlaninca</span>
                                        <input type="checkbox" class="toggle toggle-primary toggle-xs"
                                               checked="@pref.NotifyOnSpeci"
                                               @onchange="e => pref.NotifyOnSpeci = (bool)(e.Value ?? false)" />
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-xs text-base-content">VFR kosullari saglaninca</span>
                                        <input type="checkbox" class="toggle toggle-primary toggle-xs"
                                               checked="@pref.NotifyOnVfrAchieved"
                                               @onchange="e => pref.NotifyOnVfrAchieved = (bool)(e.Value ?? false)" />
                                    </div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-xs text-base-content">TS/CB onemli hava</span>
                                        <input type="checkbox" class="toggle toggle-primary toggle-xs"
                                               checked="@pref.NotifyOnSignificantWeather"
                                               @onchange="e => pref.NotifyOnSignificantWeather = (bool)(e.Value ?? false)" />
                                    </div>

                                    <div class="divider my-0.5"></div>

                                    <div class="flex items-center justify-between">
                                        <div>
                                            <div class="text-xs text-base-content">Rüzgar esigi</div>
                                            <div class="text-[0.6rem] text-base-content/40">0 = kapali</div>
                                        </div>
                                        <div class="flex items-center gap-1">
                                            <input type="number" class="input input-bordered input-xs w-14 text-center tabular-nums"
                                                   min="0" max="99"
                                                   value="@(pref.WindThresholdKnots ?? 0)"
                                                   @onchange="e => pref.WindThresholdKnots = int.TryParse(e.Value?.ToString(), out var v) && v > 0 ? v : null" />
                                            <span class="text-[0.6rem] text-base-content/40">kt</span>
                                        </div>
                                    </div>

                                    <div class="divider my-0.5"></div>

                                    @* Aktif günler *@
                                    <div>
                                        <div class="text-xs text-base-content mb-1.5">Aktif günler</div>
                                        <div class="flex gap-1 flex-wrap">
                                            @foreach (var (label, day) in _days)
                                            {
                                                var active = pref.ActiveDays.Contains(day);
                                                <button class="btn btn-xs @(active ? "btn-primary" : "btn-outline opacity-50")"
                                                        @onclick="() => TogglePrefDay(pref, day)">
                                                    @label
                                                </button>
                                            }
                                        </div>
                                    </div>

                                    @* Aktif saatler *@
                                    <div class="flex items-center justify-between">
                                        <div class="text-xs text-base-content">Aktif saatler</div>
                                        <div class="flex items-center gap-1.5">
                                            <input type="time" class="input input-bordered input-xs w-22 tabular-nums text-center"
                                                   value="@pref.StartTime[..5]"
                                                   @oninput="e => SetPrefTime(pref, true, e.Value?.ToString())" />
                                            <span class="text-[0.6rem] text-base-content/40">—</span>
                                            <input type="time" class="input input-bordered input-xs w-22 tabular-nums text-center"
                                                   value="@pref.EndTime[..5]"
                                                   @oninput="e => SetPrefTime(pref, false, e.Value?.ToString())" />
                                        </div>
                                    </div>

                                    <div class="flex gap-2 mt-1">
                                        <button class="btn btn-primary btn-xs flex-1"
                                                disabled="@(_savingIcao == icao)"
                                                @onclick="() => SavePref(pref)">
                                            @if (_savingIcao == icao) { <span class="loading loading-spinner loading-xs"></span> }
                                            else { <span>Kaydet</span> }
                                        </button>
                                        <button class="btn btn-ghost btn-xs text-error"
                                                @onclick="() => DeletePref(icao)">
                                            Kaldir
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            @* Yeni meydan ekleme satırı *@
            @if (_addingNew)
            {
                <div class="flex gap-2 mt-2">
                    <input class="input input-bordered input-sm flex-1 font-mono uppercase"
                           placeholder="LTFM"
                           maxlength="4"
                           value="@_newIcao"
                           @oninput="e => { _newIcao = e.Value?.ToString()?.ToUpperInvariant() ?? string.Empty; _addError = null; }" />
                    <button class="btn btn-primary btn-sm"
                            disabled="@(_newIcao.Length < 4 || _addingLoading)"
                            @onclick="AddNewStation">
                        @if (_addingLoading) { <span class="loading loading-spinner loading-xs"></span> }
                        else { <span>Ekle</span> }
                    </button>
                    <button class="btn btn-ghost btn-sm" @onclick="() => { _addingNew = false; _addError = null; }">
                        Iptal
                    </button>
                </div>
                @if (_addError != null)
                {
                    <div class="text-xs text-error mt-1">@_addError</div>
                }
            }
        </div>
    </div>

    @* Sağlayıcılar *@
    <div class="card bg-base-200 border border-base-300 rounded-xl">
        <div class="card-body p-4">
            <div class="flex items-center justify-between mb-1">
                <h2 class="text-sm font-semibold text-base-content">Sağlayıcılar</h2>
                @if (_providerSaving)
                {
                    <span class="loading loading-spinner loading-xs text-primary"></span>
                }
                @if (_providerSaved)
                {
                    <span class="text-xs text-success">Kaydedildi</span>
                }
            </div>
            <div class="text-xs text-base-content/40 mb-3">Sürükleyerek öncelik sırası belirleyin.</div>

            @if (_providers.Count == 0)
            {
                <div class="text-xs text-base-content/40">Yükleniyor...</div>
            }
            else
            {
                <div class="flex flex-col gap-1.5">
                    @for (int i = 0; i < _providers.Count; i++)
                    {
                        var idx = i;
                        var p = _providers[idx];
                        <div class="flex items-center gap-2 p-2.5 rounded-lg bg-base-100 border border-base-300 @(!p.IsEnabled ? "opacity-50" : "")">
                            <div class="flex flex-col gap-0.5">
                                <button class="btn btn-ghost btn-xs px-1 py-0 min-h-0 h-4 leading-none disabled:opacity-20"
                                        disabled="@(idx == 0)"
                                        @onclick="() => MoveProvider(idx, -1)">&#9650;</button>
                                <button class="btn btn-ghost btn-xs px-1 py-0 min-h-0 h-4 leading-none disabled:opacity-20"
                                        disabled="@(idx == _providers.Count - 1)"
                                        @onclick="() => MoveProvider(idx, 1)">&#9660;</button>
                            </div>
                            <span class="w-4 text-center text-xs text-base-content/30 tabular-nums">@(idx + 1)</span>
                            <span class="flex-1 text-xs font-mono font-semibold text-base-content">@p.ProviderName</span>
                            @if (p.IsEnabled)
                            {
                                <span class="badge badge-xs @(p.IsHealthy ? "badge-success" : "badge-warning")">
                                    @(p.IsHealthy ? "OK" : "Hata")
                                </span>
                            }
                            <input type="checkbox" class="toggle toggle-primary toggle-xs"
                                   checked="@p.IsEnabled"
                                   @onchange="e => p.IsEnabled = (bool)(e.Value ?? false)" />
                        </div>
                    }
                </div>

                <button class="btn btn-primary btn-sm w-full mt-3" @onclick="SaveProviders">
                    Kaydet
                </button>
            }
        </div>
    </div>

    @* Uygulama hakkında *@
    <div class="card bg-base-200 border border-base-300 rounded-xl">
        <div class="card-body p-4">
            <h2 class="text-sm font-semibold text-base-content mb-3">Hakkında</h2>
            <div class="flex flex-col gap-1 text-sm text-base-content/60">
                <div class="flex justify-between">
                    <span>Uygulama</span>
                    <span class="font-medium text-base-content">MetarPulse</span>
                </div>
                <div class="flex justify-between">
                    <span>Versiyon</span>
                    <span class="font-mono text-base-content">1.0.5</span>
                </div>
                <div class="flex justify-between">
                    <span>Platform</span>
                    <span class="font-mono text-base-content">.NET MAUI Blazor</span>
                </div>
                <div class="flex justify-between">
                    <span>Veri kaynakları</span>
                    <span class="text-base-content">AVWX · CheckWX · MGM · AWC · NOAA</span>
                </div>
            </div>
        </div>
    </div>

</div>

@code {
    private async Task OnThemeToggle(ChangeEventArgs e)
    {
        await Theme.ToggleAsync();
        StateHasChanged();
    }

    // ── Providers ─────────────────────────────────────────────────────────────

    private List<ProviderInfo> _providers = [];
    private bool _providerSaving;
    private bool _providerSaved;

    protected override async Task OnInitializedAsync()
    {
        _providers = await Api.GetProvidersAsync();
        _prefsLoading = true;

        // Bookmark listesi = tek kaynak. Her bookmark bir bildirim tercihi satırı olarak gösterilir.
        var bookmarkIcaos = await Api.GetBookmarkIcaosAsync();
        BookmarkState.Set(bookmarkIcaos); // paylaşılan state'i güncelle

        var existingPrefs = await Api.GetAllNotificationPrefsAsync();
        var prefMap = existingPrefs.ToDictionary(p => p.StationIcao);

        _allPrefs = bookmarkIcaos.Select(icao =>
            prefMap.TryGetValue(icao, out var p) ? p : new NotificationPref
            {
                StationIcao = icao,
                StartTime   = "06:00:00",
                EndTime     = "22:00:00",
                ActiveDays  = [0, 1, 2, 3, 4, 5, 6]
            }).ToList();

        _prefsLoading = false;
    }

    private void MoveProvider(int idx, int direction)
    {
        var newIdx = idx + direction;
        if (newIdx < 0 || newIdx >= _providers.Count) return;
        var item = _providers[idx];
        _providers.RemoveAt(idx);
        _providers.Insert(newIdx, item);
    }

    private async Task SaveProviders()
    {
        _providerSaving = true;
        _providerSaved  = false;

        foreach (var p in _providers)
            await Api.SetProviderEnabledAsync(p.ProviderName, p.IsEnabled);

        var ordered  = _providers.Where(p => p.IsEnabled).Select(p => p.ProviderName).ToList();
        var global   = ordered.Where(n => n != "MGM_RASAT").ToList();
        var turkey   = ordered.ToList();
        await Api.ReorderProvidersAsync(global, turkey);

        _providerSaving = false;
        _providerSaved  = true;
        await Task.Delay(2000);
        _providerSaved  = false;
    }

    // ── Notifications ─────────────────────────────────────────────────────────

    private List<NotificationPref> _allPrefs = [];
    private bool _prefsLoading;
    private string? _expandedIcao;
    private string? _savingIcao;

    // Yeni meydan ekleme
    private bool _addingNew;
    private bool _addingLoading;
    private string _newIcao = string.Empty;
    private string? _addError;

    // (label, DayOfWeek int) — Pzt=1, Sal=2 … Paz=0
    private static readonly (string Label, int Day)[] _days =
    [
        ("Pzt", 1), ("Sal", 2), ("Car", 3), ("Per", 4), ("Cum", 5), ("Cmt", 6), ("Paz", 0)
    ];

    private void ToggleExpand(string icao) =>
        _expandedIcao = _expandedIcao == icao ? null : icao;

    private void TogglePrefDay(NotificationPref pref, int day)
    {
        if (pref.ActiveDays.Contains(day)) pref.ActiveDays.Remove(day);
        else pref.ActiveDays.Add(day);
    }

    private string NotifSummary(NotificationPref pref)
    {
        var parts = new List<string>();
        if (pref.NotifyOnEveryMetar) parts.Add("Her METAR");
        if (pref.NotifyOnCategoryChange) parts.Add("Kategori");
        if (pref.NotifyOnSignificantWeather) parts.Add("TS/CB");
        return parts.Count > 0 ? string.Join(" · ", parts) : "Kapalı";
    }

    private void ShowAddStation()
    {
        _addingNew = true;
        _newIcao = string.Empty;
    }

    private async Task AddNewStation()
    {
        if (_newIcao.Length < 4) return;
        _addingLoading = true;
        _addError = null;
        StateHasChanged();

        // Bookmark'a ekle → Dashboard + Settings her ikisine birden eklenir
        var ok = await Api.AddBookmarkAsync(_newIcao);
        if (!ok)
        {
            // Zaten varsa (Conflict 409) sessizce geç; diğer hatalarda uyar
            var alreadyTracked = _allPrefs.Any(p => p.StationIcao == _newIcao);
            if (!alreadyTracked)
            {
                _addError = $"'{_newIcao}' eklenemedi. ICAO kodu doğru mu?";
                _addingLoading = false;
                StateHasChanged();
                return;
            }
        }

        if (!_allPrefs.Any(p => p.StationIcao == _newIcao))
        {
            var existing = await Api.GetNotificationPrefAsync(_newIcao);
            var pref = existing ?? new NotificationPref
            {
                StationIcao = _newIcao,
                StartTime   = "06:00:00",
                EndTime     = "22:00:00",
                ActiveDays  = [0, 1, 2, 3, 4, 5, 6]
            };
            _allPrefs.Add(pref);
        }

        BookmarkState.Add(_newIcao); // Dashboard'a anında bildir
        _expandedIcao = _newIcao;
        _addingNew    = false;
        _addingLoading = false;
        StateHasChanged();
    }

    private async Task SavePref(NotificationPref pref)
    {
        _savingIcao = pref.StationIcao;
        StateHasChanged();
        await Api.UpsertNotificationPrefAsync(pref);
        _savingIcao = null;
        _expandedIcao = null;
        StateHasChanged();
    }

    private void SetPrefTime(NotificationPref pref, bool isStart, string? val)
    {
        if (string.IsNullOrEmpty(val)) return;
        if (isStart) pref.StartTime = val + ":00";
        else pref.EndTime = val + ":00";
    }

    private async Task DeletePref(string icao)
    {
        await Api.DeleteNotificationPrefAsync(icao);
        await Api.RemoveBookmarkAsync(icao);
        BookmarkState.Remove(icao); // Dashboard'dan anında kaldır
        _allPrefs.RemoveAll(p => p.StationIcao == icao);
        if (_expandedIcao == icao) _expandedIcao = null;
        StateHasChanged();
    }
}
