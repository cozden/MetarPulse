@page "/istasyon/{Icao}"
@inject ApiService Api
@inject NavigationManager Nav
@inject SignalRService Hub
@implements IAsyncDisposable

@* ── İstasyon Detay Sayfası ─────────────────────────────────────────────── *@

@* ── Üst bar ─────────────────────────────────────────────────────────────── *@
<div class="flex items-center gap-3 mb-4 rounded-xl @_flashClass">
    <button class="btn btn-ghost btn-circle btn-sm" @onclick="GoBack">
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </button>
    <div class="flex-1">
        <h1 class="font-mono font-bold text-xl text-base-content tracking-widest">@Icao</h1>
        @if (_metar != null)
        {
            <p class="text-xs text-base-content/40">
                @_metar.ObservationTime.ToLocalTime().ToString("dd MMM HH:mm") UTC · @_metar.AgeMinutes dk önce
            </p>
        }
    </div>
    @if (_metar != null)
    {
        <FlightCategoryBadge Category="@_metar.Category" />
    }
    <button class="btn btn-ghost btn-circle btn-sm" @onclick="RefreshMetar" disabled="@_loading">
        @if (_loading)
        {
            <span class="loading loading-spinner loading-xs"></span>
        }
        else
        {
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
        }
    </button>
</div>

@if (_loading && _metar == null)
{
    <div class="flex justify-center mt-12">
        <span class="loading loading-ring loading-lg text-primary"></span>
    </div>
}
else if (_metar == null)
{
    <div class="text-center mt-12 text-base-content/40">
        <p>METAR verisi bulunamadı.</p>
        <p class="text-sm mt-1">ICAO kodu: <span class="font-mono">@Icao</span></p>
    </div>
}
else
{
    @* ── Detay kartları ─────────────────────────────────────────────────── *@

    @* Rüzgar *@
    <div class="card bg-base-200 border border-base-300 rounded-xl mb-3">
        <div class="card-body p-3">
            <div class="text-xs text-base-content/40 uppercase tracking-wider mb-2">Rüzgar</div>
            <div class="flex items-center gap-4">
                @if (!_metar.IsVariableWind && _metar.WindDirection > 0)
                {
                    @* Pusula okucuğu *@
                    <div class="relative w-14 h-14 flex-shrink-0">
                        <div class="absolute inset-0 rounded-full border border-base-content/10 flex items-center justify-center">
                            <span class="wind-arrow text-2xl text-primary"
                                  style="transform: rotate(@(_metar.WindDirection)deg); display:inline-block;">↑</span>
                        </div>
                    </div>
                }
                <div class="flex flex-col gap-1">
                    <span class="text-2xl font-bold tabular-nums text-base-content">
                        @(_metar.IsVariableWind ? "VRB" : $"{_metar.WindDirection:D3}°")
                        <span class="text-lg font-semibold @WindSpeedColor">@_metar.WindSpeed kt</span>
                    </span>
                    @if (_metar.WindGust.HasValue)
                    {
                        <span class="text-sm text-warning">Gusting @_metar.WindGust kt</span>
                    }
                    @if (_metar.IsVariableWind && _metar.VariableWindFrom.HasValue)
                    {
                        <span class="text-sm text-base-content/50">
                            @_metar.VariableWindFrom° — @_metar.VariableWindTo°
                        </span>
                    }
                    @if (_runwayWind?.Runways.Count > 0)
                    {
                        var best = _runwayWind.Runways[0];
                        <div class="flex items-center gap-3 mt-1">
                            <div class="flex items-center gap-1">
                                <span class="text-[0.6rem] text-base-content/40 uppercase tracking-wider">HeadWind</span>
                                <span class="text-sm font-semibold tabular-nums text-vfr">@best.HeadwindKnots.ToString("F0")kt</span>
                            </div>
                            <div class="flex items-center gap-1">
                                <span class="text-[0.6rem] text-base-content/40 uppercase tracking-wider">CrossWind</span>
                                <span class="text-sm font-semibold tabular-nums @XwColor(best.CrosswindKnots)">@best.CrosswindKnots.ToString("F0")kt</span>
                            </div>
                            @if (best.IsTailwind)
                            {
                                <div class="flex items-center gap-1">
                                    <span class="text-[0.6rem] text-error/70 uppercase tracking-wider">TW</span>
                                    <span class="text-sm font-semibold tabular-nums text-error">@best.TailwindKnots.ToString("F0")kt</span>
                                </div>
                            }
                            <span class="text-[0.6rem] text-base-content/30 ml-1">(@best.RunwayIdent)</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Görüş & Tavan *@
    <div class="grid grid-cols-2 gap-3 mb-3">
        <div class="card bg-base-200 border border-base-300 rounded-xl">
            <div class="card-body p-3">
                <div class="text-xs text-base-content/40 uppercase tracking-wider mb-1">Görüş</div>
                <span class="text-2xl font-bold tabular-nums @VisibilityColor">
                    @_metar.VisibilitySummary
                </span>
            </div>
        </div>
        <div class="card bg-base-200 border border-base-300 rounded-xl">
            <div class="card-body p-3">
                <div class="text-xs text-base-content/40 uppercase tracking-wider mb-1">Tavan</div>
                <span class="text-2xl font-bold tabular-nums @CeilingColor">
                    @_metar.CeilingSummary
                </span>
            </div>
        </div>
    </div>

    @* Bulut katmanları *@
    @if (_metar.CloudLayers.Count > 0)
    {
        <div class="card bg-base-200 border border-base-300 rounded-xl mb-3">
            <div class="card-body p-3">
                <div class="text-xs text-base-content/40 uppercase tracking-wider mb-2">Bulutlar</div>
                <div class="flex flex-col gap-1.5">
                    @foreach (var cl in _metar.CloudLayers)
                    {
                        <div class="flex items-center justify-between">
                            <span class="font-mono font-semibold text-sm text-base-content">@cl.Coverage</span>
                            <span class="tabular-nums text-sm text-base-content/70">@cl.AltitudeFt.ToString("N0") ft</span>
                            @if (cl.Type is not ("None" or ""))
                            {
                                <span class="badge badge-warning badge-xs">@cl.Type</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @* Sıcaklık & Basınç *@
    <div class="grid grid-cols-3 gap-3 mb-3">
        <div class="card bg-base-200 border border-base-300 rounded-xl">
            <div class="card-body p-3">
                <div class="text-xs text-base-content/40 uppercase tracking-wider mb-1">Sıcaklık</div>
                <span class="text-xl font-bold tabular-nums">@(_metar.Temperature?.ToString() ?? "—")°C</span>
            </div>
        </div>
        <div class="card bg-base-200 border border-base-300 rounded-xl">
            <div class="card-body p-3">
                <div class="text-xs text-base-content/40 uppercase tracking-wider mb-1">Çiy N.</div>
                <span class="text-xl font-bold tabular-nums">@(_metar.DewPoint?.ToString() ?? "—")°C</span>
            </div>
        </div>
        <div class="card bg-base-200 border border-base-300 rounded-xl">
            <div class="card-body p-3">
                <div class="text-xs text-base-content/40 uppercase tracking-wider mb-1">QNH</div>
                <span class="text-xl font-bold tabular-nums">@_metar.QnhSummary</span>
            </div>
        </div>
    </div>

    @* Hava olayları *@
    @if (_metar.WeatherConditions.Count > 0)
    {
        <div class="card bg-base-200 border border-base-300 rounded-xl mb-3">
            <div class="card-body p-3">
                <div class="text-xs text-base-content/40 uppercase tracking-wider mb-2">Hava Olayları</div>
                <div class="flex flex-wrap gap-2">
                    @foreach (var wx in _metar.WeatherConditions)
                    {
                        <span class="badge badge-info badge-outline font-mono">@wx</span>
                    }
                </div>
            </div>
        </div>
    }

    @* Ham METAR *@
    <div class="card bg-base-200 border border-base-300 rounded-xl mb-3">
        <div class="card-body p-3">
            <div class="flex items-center justify-between mb-2">
                <div class="text-xs text-base-content/40 uppercase tracking-wider">Ham METAR</div>
                @if (_metar.SourceProvider != null)
                {
                    <span class="badge badge-ghost badge-xs opacity-50">@_metar.SourceProvider</span>
                }
            </div>
            <div class="raw-metar text-base-content/60 select-all">@_metar.RawText</div>
        </div>
    </div>

    @* TAF *@
    @if (_taf != null)
    {
        <div class="card bg-base-200 border border-base-300 rounded-xl mb-3">
            <div class="card-body p-3">
                <div class="flex items-center justify-between mb-2">
                    <div class="text-xs text-base-content/40 uppercase tracking-wider">TAF</div>
                    <span class="text-xs text-base-content/30 tabular-nums">
                        @_taf.ValidFrom.ToLocalTime().ToString("dd MMM HH:mm") — @_taf.ValidTo.ToLocalTime().ToString("dd MMM HH:mm")
                    </span>
                </div>

                @* Periyotlar *@
                <div class="flex flex-col divide-y divide-base-300/40">
                    @foreach (var p in _taf.Periods)
                    {
                        <div class="py-2 first:pt-0 last:pb-0">
                            @* Zaman + değişim tipi *@
                            <div class="flex items-center gap-2 mb-1">
                                <span class="font-mono text-xs font-semibold @TafPeriodColor(p.ChangeIndicator)">
                                    @(string.IsNullOrEmpty(p.ChangeIndicator) ? "BASE" : p.ChangeIndicator)
                                    @if (p.Probability.HasValue)
                                    {
                                        <span class="text-base-content/40">PROB@(p.Probability)</span>
                                    }
                                </span>
                                <span class="text-[0.65rem] text-base-content/40 tabular-nums">
                                    @p.From.ToLocalTime().ToString("dd MMM HH:mm") → @p.To.ToLocalTime().ToString("dd MMM HH:mm")
                                </span>
                            </div>
                            @* Rüzgar + Görüş + Bulut *@
                            <div class="flex flex-wrap gap-x-4 gap-y-0.5 text-xs text-base-content/70">
                                @if (p.WindDirection.HasValue && p.WindSpeed.HasValue)
                                {
                                    <span class="tabular-nums">
                                        <span class="text-base-content/40">WND</span>
                                        @($"{p.WindDirection:D3}°/{p.WindSpeed}kt")
                                        @if (p.WindGust.HasValue)
                                        {
                                            <span class="text-warning"> G@(p.WindGust)kt</span>
                                        }
                                    </span>
                                }
                                @if (p.VisibilityMeters.HasValue)
                                {
                                    <span class="tabular-nums">
                                        <span class="text-base-content/40">VIS</span>
                                        @(p.VisibilityMeters >= 9999 ? "9999m" : $"{p.VisibilityMeters}m")
                                    </span>
                                }
                                @foreach (var wx in p.WeatherConditions)
                                {
                                    <span class="font-mono text-info">@wx</span>
                                }
                                @foreach (var cl in p.CloudLayers)
                                {
                                    <span class="tabular-nums">@cl.Coverage @(cl.AltitudeFt.ToString("N0"))ft@(cl.Type is not ("None" or "") ? $" {cl.Type}" : "")</span>
                                }
                            </div>
                        </div>
                    }
                </div>

                @* Ham TAF *@
                <div class="raw-metar text-base-content/40 pt-2 mt-1 border-t border-base-300/50">
                    @_taf.RawText
                </div>
            </div>
        </div>
    }

    @* Pist Rüzgar Analizi *@
    @if (_runwayWind != null && _runwayWind.Runways.Count > 0)
    {
        <div class="card bg-base-200 border border-base-300 rounded-xl mb-3">
            <div class="card-body p-3">
                <div class="flex items-center justify-between mb-1">
                    <div class="text-xs text-base-content/40 uppercase tracking-wider">Pist Analizi</div>
                    <span class="text-xs text-base-content/30">
                        @_runwayWind.WindDirection°/@_runwayWind.WindSpeed kt
                        @if (_runwayWind.WindGust.HasValue)
                        {
                            <span> G@(_runwayWind.WindGust)kt</span>
                        }
                    </span>
                </div>
                <div class="divide-y divide-base-300/40">
                    @for (int i = 0; i < _runwayWind.Runways.Count; i++)
                    {
                        var rwy = _runwayWind.Runways[i];
                        <RunwayWindCard RunwayIdent="@rwy.RunwayIdent"
                                        HeadingDeg="@rwy.HeadingDeg"
                                        HeadwindKnots="@rwy.HeadwindKnots"
                                        CrosswindKnots="@rwy.CrosswindKnots"
                                        TailwindKnots="@rwy.TailwindKnots"
                                        IsTailwind="@rwy.IsTailwind"
                                        IsOptimal="@(i == 0)"
                                        LengthFt="@rwy.LengthFt" />
                    }
                </div>
            </div>
        </div>
    }

    @* Bookmark butonu *@
    <button class="btn btn-outline btn-sm w-full @(_isBookmarked ? "btn-error" : "btn-primary")"
            @onclick="ToggleBookmark">
        @if (_isBookmarked)
        {
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6 2a2 2 0 00-2 2v18l8-3 8 3V4a2 2 0 00-2-2H6z"/>
            </svg>
            <span>Kaydedildi &mdash; Kaldır</span>
        }
        else
        {
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
            </svg>
            <span>Dashboard'a Ekle</span>
        }
    </button>
}

@code {
    [Parameter] public string Icao { get; set; } = string.Empty;

    private MetarViewModel? _metar;
    private RunwayWindResult? _runwayWind;
    private TafResult? _taf;
    private bool _loading;
    private bool _isBookmarked;
    private string _flashClass = "";
    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        Hub.OnMetarReceived += HandleMetarReceived;
        try
        {
            var metarTask  = Api.GetMetarAsync(Icao, _cts.Token);
            var icaosTask  = Api.GetBookmarkIcaosAsync(_cts.Token);
            var runwayTask = Api.GetRunwayWindAsync(Icao, _cts.Token);
            var tafTask    = Api.GetTafAsync(Icao, _cts.Token);
            await Task.WhenAll(metarTask, icaosTask, runwayTask, tafTask);
            _metar       = metarTask.Result;
            _runwayWind  = runwayTask.Result;
            _taf         = tafTask.Result;
            var icaos    = icaosTask.Result;
            _isBookmarked = icaos.Contains(Icao.ToUpperInvariant(), StringComparer.OrdinalIgnoreCase);
        }
        finally { _loading = false; }

        await Hub.ConnectAsync(_cts.Token);
        await Hub.JoinStationAsync(Icao);
    }

    private void HandleMetarReceived(string icao, object? payload)
    {
        if (!icao.Equals(Icao, StringComparison.OrdinalIgnoreCase)) return;
        _ = InvokeAsync(async () =>
        {
            try
            {
                var fresh = await Api.GetMetarAsync(Icao, _cts.Token);
                if (fresh is null) return;
                _metar = fresh;
                _flashClass = $"flash-{_metar.Category.ToString().ToLower()}";
                StateHasChanged();
                await Task.Delay(5000);
                _flashClass = "";
                StateHasChanged();
            }
            catch { }
        });
    }

    private async Task RefreshMetar()
    {
        _loading = true;
        try { _metar = await Api.RefreshMetarAsync(Icao, _cts.Token); }
        finally { _loading = false; }
    }

    private async Task ToggleBookmark()
    {
        if (_isBookmarked)
        {
            await Api.RemoveBookmarkAsync(Icao, _cts.Token);
            _isBookmarked = false;
        }
        else
        {
            await Api.AddBookmarkAsync(Icao, _cts.Token);
            _isBookmarked = true;
        }
    }

    private void GoBack() => Nav.NavigateTo("/");

    private static string TafPeriodColor(string indicator) => indicator switch
    {
        "TEMPO"  => "text-warning",
        "BECMG"  => "text-info",
        var s when s.StartsWith("FM") => "text-primary",
        _ => "text-base-content/70"
    };

    private static string XwColor(double xw) => xw switch
    {
        > 20 => "text-lifr",
        > 15 => "text-ifr",
        > 10 => "text-warning",
        _    => "text-mvfr"
    };

    private string WindSpeedColor => _metar?.WindSpeed switch
    {
        >= 30 => "text-error",
        >= 15 => "text-warning",
        _ => "text-base-content"
    };

    private string VisibilityColor => _metar?.VisibilityMeters switch
    {
        >= 5000 => "text-vfr",
        >= 3000 => "text-mvfr",
        >= 800  => "text-ifr",
        _ => "text-lifr"
    };

    private string CeilingColor => _metar?.CeilingFeet switch
    {
        >= 3000 => "text-vfr",
        >= 1000 => "text-mvfr",
        >= 500  => "text-ifr",
        _ => "text-lifr"
    };

    public async ValueTask DisposeAsync()
    {
        Hub.OnMetarReceived -= HandleMetarReceived;
        await Hub.LeaveStationAsync(Icao);
        _cts.Cancel();
        _cts.Dispose();
    }
}
