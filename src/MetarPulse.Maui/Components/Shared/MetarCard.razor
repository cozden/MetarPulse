@* METAR Kartı — Dashboard ve liste için *@
<div class="metar-card card bg-base-200 border border-base-300 card-@(Metar.CategoryCssClass) @(Metar.IsStale ? "stale-overlay" : "") @(IsFlashing ? $"flash-{Metar.CategoryCssClass}" : "") fade-in"
     @onclick="OnClick">
    <div class="card-body p-3 gap-2">

        @* ── Üst satır: ICAO + Kategori + Yaş ────────────────────────────── *@
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
                <span class="font-mono font-bold text-lg text-base-content tracking-widest">
                    @Metar.StationId
                </span>
                @if (Metar.IsSpeci)
                {
                    <span class="badge badge-warning badge-xs">SPECI</span>
                }
                @if (Metar.IsStale)
                {
                    <span class="badge badge-ghost badge-xs opacity-60">BAYAT</span>
                }
                @if (NotamSummary is not null && NotamSummary.HasAny)
                {
                    <span class="badge badge-xs @NotamSummary.BadgeCss" title="NOTAM">N @NotamSummary.ActiveCount</span>
                }
            </div>
            <div class="flex items-center gap-2">
                <FlightCategoryBadge Category="@Metar.Category" />
                <span class="text-xs text-base-content/40 tabular-nums">
                    @Metar.AgeMinutes dk önce
                </span>
            </div>
        </div>

        @* ── Orta satır: Rüzgar | Görüş | Tavan | QNH ────────────────────── *@
        <div class="grid grid-cols-4 gap-1 text-center">
            <div class="flex flex-col items-center">
                <span class="text-[0.6rem] text-base-content/40 uppercase tracking-wider mb-0.5">Rüzgar</span>
                <WindIndicator Direction="@Metar.WindDirection"
                               Speed="@Metar.WindSpeed"
                               Gust="@Metar.WindGust"
                               IsVariable="@Metar.IsVariableWind" />
            </div>
            <div class="flex flex-col items-center">
                <span class="text-[0.6rem] text-base-content/40 uppercase tracking-wider mb-0.5">Görüş</span>
                <span class="font-semibold text-sm tabular-nums @VisibilityColor">
                    @Metar.VisibilitySummary
                </span>
            </div>
            <div class="flex flex-col items-center">
                <span class="text-[0.6rem] text-base-content/40 uppercase tracking-wider mb-0.5">Tavan</span>
                <span class="font-semibold text-sm tabular-nums @CeilingColor">
                    @Metar.CeilingSummary
                </span>
            </div>
            <div class="flex flex-col items-center">
                <span class="text-[0.6rem] text-base-content/40 uppercase tracking-wider mb-0.5">QNH</span>
                <span class="font-semibold text-sm tabular-nums text-base-content">
                    @Metar.QnhSummary
                </span>
            </div>
        </div>

        @* ── Sıcaklık / çiy noktası + trend ──────────────────────────────── *@
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                @if (Metar.Temperature.HasValue)
                {
                    <span class="text-xs tabular-nums">
                        <span class="text-base-content/50">T/D:</span>
                        <span class="text-base-content font-medium">@Metar.Temperature°/@Metar.DewPoint°C</span>
                    </span>
                }
                @if (Metar.WeatherConditions.Count > 0)
                {
                    <span class="text-xs text-info font-mono">
                        @string.Join(" ", Metar.WeatherConditions)
                    </span>
                }
            </div>
            @if (!string.IsNullOrEmpty(Metar.Trend) && Metar.Trend != "NOSIG")
            {
                <span class="badge badge-outline badge-xs text-warning border-warning/40">@Metar.Trend</span>
            }
        </div>

        @* ── Ham METAR (opsiyonel) ─────────────────────────────────────────── *@
        @if (ShowRaw)
        {
            <div class="raw-metar text-base-content/40 pt-1 border-t border-base-300/50">
                @Metar.RawText
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public MetarViewModel Metar { get; set; } = default!;
    [Parameter] public bool ShowRaw { get; set; } = false;
    [Parameter] public bool IsFlashing { get; set; } = false;
    [Parameter] public NotamSummaryViewModel? NotamSummary { get; set; }
    [Parameter] public EventCallback<MetarViewModel> OnCardClick { get; set; }

    private async Task OnClick() => await OnCardClick.InvokeAsync(Metar);

    private string VisibilityColor => Metar.VisibilityMeters switch
    {
        >= 5000 => "text-vfr",
        >= 3000 => "text-mvfr",
        >= 800  => "text-ifr",
        _       => "text-lifr"
    };

    private string CeilingColor => Metar.CeilingFeet switch
    {
        >= 3000 => "text-vfr",
        >= 1000 => "text-mvfr",
        >= 500  => "text-ifr",
        _       => "text-lifr"
    };
}
